{
  "name": "@carloi-v4/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --ignore-watch node_modules src/main.ts",
    "build": "node ../../node_modules/typescript/bin/tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "typecheck": "node ../../node_modules/typescript/bin/tsc --noEmit -p tsconfig.json",
    "test": "pnpm run build && node --test --test-concurrency=1 test/**/*.test.mjs",
    "test:unit": "pnpm run build && node --test test/auth.unit.test.mjs",
    "test:e2e": "pnpm run build && node --test test/auth.e2e.test.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.922.0",
    "@aws-sdk/s3-request-presigner": "^3.922.0",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/platform-express": "^11.1.19",
    "@prisma/client": "^6.19.3",
    "bullmq": "^5.58.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.2",
    "openai": "^6.34.0",
    "pino": "^10.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "ts-node-dev": "^2.0.0"
  }
}
