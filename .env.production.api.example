NODE_ENV="production"
PORT="3001"
DATABASE_URL="postgresql://carloi:replace-me@postgres:5432/carloi_v4?schema=public"
POSTGRES_DB="carloi_v4"
POSTGRES_USER="carloi"
POSTGRES_PASSWORD="replace-me"
REDIS_URL="redis://:replace-me@redis:6379/0"
REDIS_HOST="redis"
REDIS_PORT="6379"
REDIS_PASSWORD="replace-me"
REDIS_DB="0"
TRUST_PROXY="1"
CORS_ORIGINS="https://app.carloi.example,https://www.carloi.example,https://admin.carloi.example"
GLOBAL_RATE_LIMIT_MAX="300"
GLOBAL_RATE_LIMIT_WINDOW_MS="60000"
LOG_LEVEL="info"
LOG_DIR="logs"
ENABLE_FILE_LOGS="true"
UPTIME_LOG_INTERVAL_MS="900000"
JWT_ACCESS_SECRET="replace-me"
JWT_REFRESH_SECRET="replace-me"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="14d"
ADMIN_JWT_SECRET="replace-me"
ADMIN_JWT_ACCESS_SECRET="replace-me"
ADMIN_JWT_REFRESH_SECRET="replace-me"
ADMIN_JWT_ACCESS_EXPIRES_IN="15m"
ADMIN_JWT_REFRESH_EXPIRES_IN="14d"
BREVO_API_KEY="replace-me"
BREVO_SMS_SENDER="Carloi"
BREVO_EMAIL_SENDER="no-reply@carloi.example"
GARANTI_MERCHANT_ID="replace-me"
GARANTI_TERMINAL_ID="replace-me"
GARANTI_PROVISION_USER="replace-me"
GARANTI_PROVISION_PASSWORD="replace-me"
GARANTI_STORE_KEY="replace-me"
GARANTI_SUCCESS_URL="https://app.carloi.example/payments/result"
GARANTI_FAIL_URL="https://app.carloi.example/payments/result"
GARANTI_MODE="production"
OPENAI_API_KEY="replace-me"
DEEPSEEK_API_KEY="replace-me"
LOI_AI_DAILY_LIMIT="40"
MEDIA_STORAGE_PROVIDER="s3"
LOCAL_UPLOAD_DIR="uploads"
PUBLIC_MEDIA_BASE_URL="https://api.carloi.example/uploads"
S3_BUCKET="replace-me"
S3_REGION="replace-me"
S3_ACCESS_KEY="replace-me"
S3_SECRET_KEY="replace-me"
S3_ENDPOINT=""
S3_FORCE_PATH_STYLE="false"
S3_PUBLIC_BASE_URL="https://cdn.carloi.example"
S3_SIGNED_URL_EXPIRES_IN="900"
BACKUP_SCHEDULE="0 3 * * *"
BACKUP_RETENTION_DAYS="7"
ADMIN_SEED_PASSWORD="replace-me"
SEED_USER_PASSWORD="replace-me"